# Copy this to .env for local dev, set these in Railway dashboard for production

# Required
PORT=4000
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Optional — for blockchain features (leave blank for mock mode)
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
IDEA_REGISTRY_ADDRESS=0x71D9B98BC485Eb1676fCE3D127Cc205343846913
FUNDING_DAO_ADDRESS=0x623a466f63ecf83946528Ccd53c33131d91Da3BA

# Optional — for MongoDB persistence (add free MongoDB on Railway)
MONGO_URL=mongodb://mongo:password@host:27017/prooffund

# Optional — your Vercel frontend URL (auto-allowed if ends in .vercel.app)
FRONTEND_URL=https://aura-five-ashy.vercel.app

# Optional — AI features
GEMINI_API_KEY=your_gemini_key
PINATA_JWT=your_pinata_jwt
